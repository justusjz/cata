struct some_struct {
    a: i32,
    b: i32,
    c: other_struct
}

struct other_struct {
    a: i32,
    b: i32
}

fn get_a(s: some_struct) i32 {
    return s.a;
}

fn test(a: i32, b: i32) i32 {
    var c: other_struct = other_struct{3, 4};
    var s: some_struct = some_struct{5, 6, c};
    return get_a(s);
}
