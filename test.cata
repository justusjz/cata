struct some_struct {
    a: i32,
    b: i32,
    c: other_struct
}

struct other_struct {
    a: i32,
    b: i32,
    c: bool
}

fn get_a(s: some_struct) i32 {
    var c: some_struct = s;
    c.a = 3;
    return s.a;
}

fn update_c(o: other_struct, target: bool) other_struct {
    var my: other_struct = o;
    my.c = target;
    return my;
}

fn threeway_if(a: bool, b: bool, c: bool) i32 {
    if (a) {
        return 0;
    } else if (b) {
        return 1;
    } else if (c) {
        return 2;
    } else {
        return 3;
    }
}

fn loop() i32 {
    var b: bool = true;
    while (b) {
        var c: i32 = 0;
        return c;
    }
    return 9;
}

fn test(a: i32, b: i32) i32 {
    var c: other_struct = other_struct{3, 4, false};
    c = update_c(c, true);
    if (c.c) {
        return 0;
    }
    var s: some_struct = some_struct{5, 6, c};
    return get_a(s);
}
